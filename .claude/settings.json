{
  "model": "claude-sonnet-4-6",

  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(ls *)",
      "Bash(open *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[自動記録] ファイルを作成・更新しました: ' $(date '+%Y-%m-%d %H:%M:%S') >> /tmp/claude_seminar.log"
          }
        ]
      }
    ]
  }
}
